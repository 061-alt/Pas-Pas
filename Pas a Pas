import React, { useState, useEffect, useMemo } from 'react';
import { 
  XAxis, 
  YAxis, 
  CartesianGrid, 
  Tooltip, 
  ResponsiveContainer,
  AreaChart,
  Area,
  Line
} from 'recharts';
import { 
  Scale, 
  Dumbbell, 
  ChefHat, 
  Plus, 
  History, 
  Target, 
  CheckCircle2,
  Loader2,
  Sparkles,
  UtensilsCrossed
} from 'lucide-react';
import { format, subDays, endOfMonth, differenceInDays, parseISO } from 'date-fns';
import { ja } from 'date-fns/locale';
import { motion, AnimatePresence } from 'motion/react';
import { GoogleGenAI } from "@google/genai";
import { clsx, type ClassValue } from 'clsx';
import { twMerge } from 'tailwind-merge';

// --- ユーティリティ ---
function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}

// --- 型定義 ---
interface WeightLog {
  date: string;
  weight: number;
}

interface Goals {
  initialWeight: number;
  targetWeight: number;
  targetDate: string;
  startDate: string;
}

interface ExerciseTask {
  id: string;
  label: string;
  tip: string;
  completed: boolean;
}

// --- コンポーネント ---

const Card = ({ children, className, title, icon: Icon }: { children: React.ReactNode, className?: string, title?: string, icon?: any }) => (
  <motion.div 
    initial={{ opacity: 0, y: 20 }}
    animate={{ opacity: 1, y: 0 }}
    className={cn("bg-white rounded-2xl shadow-sm border border-stone-100 overflow-hidden", className)}
  >
    {title && (
      <div className="px-6 py-4 border-b border-stone-50 flex items-center justify-between bg-stone-50/30">
        <h3 className="text-lg font-serif font-semibold text-stone-800 flex items-center gap-2">
          {Icon && <Icon className="w-5 h-5 text-sage" />}
          {title}
        </h3>
      </div>
    )}
    <div className="p-6">
      {children}
    </div>
  </motion.div>
);

const Button = ({ children, onClick, variant = 'primary', className, disabled, loading }: { 
  children: React.ReactNode, 
  onClick?: () => void, 
  variant?: 'primary' | 'secondary' | 'outline' | 'terracotta',
  className?: string,
  disabled?: boolean,
  loading?: boolean
}) => {
  const variants = {
    primary: "bg-sage text-white hover:bg-sage/90",
    secondary: "bg-gold text-white hover:bg-gold/90",
    terracotta: "bg-terracotta text-white hover:bg-terracotta/90",
    outline: "border border-stone-200 text-stone-600 hover:bg-stone-50"
  };

  return (
    <button 
      onClick={onClick}
      disabled={disabled || loading}
      className={cn(
        "px-5 py-2.5 rounded-full font-medium transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed",
        variants[variant],
        className
      )}
    >
      {loading && <Loader2 className="w-4 h-4 animate-spin" />}
      {children}
    </button>
  );
};

export default function App() {
  // --- ステート ---
  const [weightLogs, setWeightLogs] = useState<WeightLog[]>([]);
  const [goals, setGoals] = useState<Goals | null>(null);
  const [exercises, setExercises] = useState<ExerciseTask[]>([
    { id: 'walking', label: '20分ウォーキング', tip: '心拍数を少し上げるくらいのペースで歩きましょう。', completed: false },
    { id: 'squats', label: 'スクワット', tip: 'かかとに重心を置き、椅子に座るイメージで。', completed: false },
    { id: 'plank', label: 'プランク', tip: '頭からかかとまで一直線を意識しましょう。', completed: false },
    { id: 'lunges', label: 'ランジ', tip: '前足の膝がつま先より前に出ないように。', completed: false },
  ]);
  const [ingredients, setIngredients] = useState('');
  const [recipe, setRecipe] = useState<string | null>(null);
  const [isGenerating, setIsGenerating] = useState(false);
  
  const [newWeight, setNewWeight] = useState('');
  const [goalInput, setGoalInput] = useState({
    targetWeight: '',
    targetDate: ''
  });

  // --- データの永続化 ---
  useEffect(() => {
    const savedLogs = localStorage.getItem('ps_weight_logs');
    const savedGoals = localStorage.getItem('ps_goals');
    const savedExercises = localStorage.getItem('ps_exercises');
    
    if (savedLogs) setWeightLogs(JSON.parse(savedLogs));
    if (savedGoals) setGoals(JSON.parse(savedGoals));
    if (savedExercises) {
      const parsed = JSON.parse(savedExercises);
      const lastUpdate = localStorage.getItem('ps_exercise_date');
      if (lastUpdate === format(new Date(), 'yyyy-MM-dd')) {
        setExercises(parsed);
      }
    }
  }, []);

  useEffect(() => {
    localStorage.setItem('ps_weight_logs', JSON.stringify(weightLogs));
    localStorage.setItem('ps_goals', JSON.stringify(goals));
    localStorage.setItem('ps_exercises', JSON.stringify(exercises));
    localStorage.setItem('ps_exercise_date', format(new Date(), 'yyyy-MM-dd'));
  }, [weightLogs, goals, exercises]);

  // --- ロジック ---
  const addWeightLog = () => {
    const weight = parseFloat(newWeight);
    if (isNaN(weight)) return;

    const today = format(new Date(), 'yyyy-MM-dd');
    const existingIndex = weightLogs.findIndex(log => log.date === today);

    if (existingIndex >= 0) {
      const updated = [...weightLogs];
      updated[existingIndex].weight = weight;
      setWeightLogs(updated);
    } else {
      setWeightLogs([...weightLogs, { date: today, weight }].sort((a, b) => a.date.localeCompare(b.date)));
    }
    
    if (!goals) {
      setGoals({
        initialWeight: weight,
        targetWeight: weight - 5,
        targetDate: format(subDays(new Date(), -30), 'yyyy-MM-dd'),
        startDate: today
      });
    }
    
    setNewWeight('');
  };

  const updateGoals = () => {
    const target = parseFloat(goalInput.targetWeight);
    if (isNaN(target) || !goalInput.targetDate) return;

    const latestWeight = weightLogs.length > 0 ? weightLogs[weightLogs.length - 1].weight : 70;

    setGoals({
      initialWeight: latestWeight,
      targetWeight: target,
      targetDate: goalInput.targetDate,
      startDate: format(new Date(), 'yyyy-MM-dd')
    });
  };

  const milestones = useMemo(() => {
    if (!goals || weightLogs.length === 0) return null;

    const start = parseISO(goals.startDate);
    const end = parseISO(goals.targetDate);
    const today = new Date();
    const monthEnd = endOfMonth(today);

    const totalDays = differenceInDays(end, start);
    const daysPassed = differenceInDays(today, start);
    const daysToMonthEnd = differenceInDays(monthEnd, start);

    if (totalDays <= 0) return null;

    const totalWeightToLose = goals.initialWeight - goals.targetWeight;
    const dailyRate = totalWeightToLose / totalDays;

    const todayTarget = goals.initialWeight - (dailyRate * daysPassed);
    const monthEndTarget = goals.initialWeight - (dailyRate * daysToMonthEnd);

    const currentWeight = weightLogs[weightLogs.length - 1].weight;

    return {
      todayTarget: todayTarget.toFixed(1),
      monthEndTarget: monthEndTarget.toFixed(1),
      diffToday: (currentWeight - todayTarget).toFixed(1),
      diffMonth: (currentWeight - monthEndTarget).toFixed(1)
    };
  }, [goals, weightLogs]);

  const chartData = useMemo(() => {
    if (weightLogs.length === 0) return [];
    
    const data = [];
    for (let i = 13; i >= 0; i--) {
      const d = subDays(new Date(), i);
      const dateStr = format(d, 'yyyy-MM-dd');
      const log = weightLogs.find(l => l.date === dateStr);
      
      let avg = null;
      const logsForAvg = weightLogs.filter(l => {
        const logDate = parseISO(l.date);
        const diff = differenceInDays(d, logDate);
        return diff >= 0 && diff < 7;
      });
      
      if (logsForAvg.length > 0) {
        avg = logsForAvg.reduce((sum, l) => sum + l.weight, 0) / logsForAvg.length;
      }

      data.push({
        name: format(d, 'M/d', { locale: ja }),
        weight: log ? log.weight : null,
        average: avg ? parseFloat(avg.toFixed(1)) : null
      });
    }
    return data;
  }, [weightLogs]);

  const generateRecipe = async () => {
    if (!ingredients.trim()) return;
    
    setIsGenerating(true);
    try {
      const ai = new GoogleGenAI({ apiKey: process.env.GEMINI_API_KEY! });
      const response = await ai.models.generateContent({
        model: "gemini-3-flash-preview",
        contents: `以下の食材を使って、ヘルシーで低カロリーなレシピを作成してください：${ingredients}。
        回答は日本語で、丁寧な言葉遣い（です・ます調）でお願いします。
        タイトル、調理時間、材料リスト、明確な手順を含めてMarkdown形式で出力してください。
        上品で簡潔な内容にしてください。`,
      });
      setRecipe(response.text || "申し訳ありません。レシピを生成できませんでした。");
    } catch (error) {
      console.error(error);
      setRecipe("エラーが発生しました。もう一度お試しください。");
    } finally {
      setIsGenerating(false);
    }
  };

  const toggleExercise = (id: string) => {
    setExercises(prev => prev.map(ex => ex.id === id ? { ...ex, completed: !ex.completed } : ex));
  };

  return (
    <div className="min-h-screen pb-20">
      {/* --- ヘッダー --- */}
      <header className="bg-white border-b border-stone-100 sticky top-0 z-50">
        <div className="max-w-5xl mx-auto px-6 h-20 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-sage rounded-xl flex items-center justify-center text-white shadow-lg shadow-sage/20">
              <Sparkles className="w-6 h-6" />
            </div>
            <h1 className="text-2xl font-serif font-bold tracking-tight text-stone-800">Petit Santé</h1>
          </div>
          <div className="hidden md:flex items-center gap-6 text-sm font-medium text-stone-500">
            <a href="#tracker" className="hover:text-sage transition-colors">体重管理</a>
            <a href="#exercises" className="hover:text-sage transition-colors">宅トレ</a>
            <a href="#recipes" className="hover:text-sage transition-colors">レシピ</a>
          </div>
        </div>
      </header>

      <main className="max-w-5xl mx-auto px-6 pt-10 space-y-10">
        
        {/* --- ヒーローセクション --- */}
        <section className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <Card className="lg:col-span-2 bg-gradient-to-br from-sage/5 to-transparent border-sage/20">
            <div className="flex flex-col md:flex-row md:items-center justify-between gap-6">
              <div>
                <span className="text-xs font-bold uppercase tracking-widest text-sage mb-2 block">Bienvenue</span>
                <h2 className="text-3xl font-serif font-bold text-stone-900 mb-2">健やかな毎日を</h2>
                <p className="text-stone-500 max-w-md">優雅に、そして着実に。小さな一歩が、美しい変化へと繋がります。</p>
              </div>
              <div className="flex items-center gap-4">
                <div className="text-right">
                  <p className="text-xs font-bold text-stone-400 uppercase tracking-tighter">現在の体重</p>
                  <p className="text-4xl font-serif font-bold text-sage">
                    {weightLogs.length > 0 ? weightLogs[weightLogs.length - 1].weight : '--'}
                    <span className="text-lg ml-1">kg</span>
                  </p>
                </div>
              </div>
            </div>
          </Card>

          <Card title="目標までのステップ" icon={Target} className="bg-stone-900 text-white border-none">
            {milestones ? (
              <div className="space-y-6">
                <div>
                  <div className="flex justify-between items-end mb-1">
                    <p className="text-stone-400 text-xs uppercase font-bold tracking-wider">今日の目標</p>
                    <p className="text-xl font-serif font-bold">{milestones.todayTarget} kg</p>
                  </div>
                  <div className="h-1 bg-stone-800 rounded-full overflow-hidden">
                    <div 
                      className="h-full bg-gold transition-all duration-1000" 
                      style={{ width: `${Math.max(0, Math.min(100, (goals!.initialWeight - (weightLogs[weightLogs.length-1].weight)) / (goals!.initialWeight - goals!.targetWeight) * 100))}%` }}
                    />
                  </div>
                  <p className={cn("text-[10px] mt-2", parseFloat(milestones.diffToday) <= 0 ? "text-emerald-400" : "text-terracotta")}>
                    {parseFloat(milestones.diffToday) <= 0 ? '順調に進んでいます' : `今日の目標まであと ${milestones.diffToday}kg です`}
                  </p>
                </div>
                <div>
                  <div className="flex justify-between items-end mb-1">
                    <p className="text-stone-400 text-xs uppercase font-bold tracking-wider">今月末の目標</p>
                    <p className="text-xl font-serif font-bold">{milestones.monthEndTarget} kg</p>
                  </div>
                  <p className="text-[10px] mt-1 text-stone-500">
                    月末までにあと {milestones.diffMonth}kg の減量を目指しましょう。
                  </p>
                </div>
              </div>
            ) : (
              <div className="py-4 text-center">
                <p className="text-stone-500 text-sm">目標を設定して、進捗を確認しましょう。</p>
              </div>
            )}
          </Card>
        </section>

        {/* --- 体重管理セクション --- */}
        <section id="tracker" className="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <div className="lg:col-span-2 space-y-6">
            <Card title="体重の推移" icon={History}>
              <div className="h-[300px] w-full">
                <ResponsiveContainer width="100%" height="100%">
                  <AreaChart data={chartData}>
                    <defs>
                      <linearGradient id="colorWeight" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="5%" stopColor="#B2AC88" stopOpacity={0.3}/>
                        <stop offset="95%" stopColor="#B2AC88" stopOpacity={0}/>
                      </linearGradient>
                    </defs>
                    <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#f0f0f0" />
                    <XAxis 
                      dataKey="name" 
                      axisLine={false} 
                      tickLine={false} 
                      tick={{ fontSize: 10, fill: '#A8A29E' }}
                      dy={10}
                    />
                    <YAxis 
                      hide 
                      domain={['dataMin - 2', 'dataMax + 2']} 
                    />
                    <Tooltip 
                      contentStyle={{ borderRadius: '12px', border: 'none', boxShadow: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }}
                    />
                    <Area 
                      type="monotone" 
                      dataKey="weight" 
                      stroke="#B2AC88" 
                      strokeWidth={3}
                      fillOpacity={1} 
                      fill="url(#colorWeight)" 
                      connectNulls
                    />
                    <Line 
                      type="monotone" 
                      dataKey="average" 
                      stroke="#D4AF37" 
                      strokeWidth={2} 
                      strokeDasharray="5 5" 
                      dot={false}
                    />
                  </AreaChart>
                </ResponsiveContainer>
              </div>
              <div className="mt-4 flex items-center justify-center gap-6 text-xs text-stone-400">
                <div className="flex items-center gap-2">
                  <div className="w-3 h-3 bg-sage rounded-full" />
                  <span>日々の体重</span>
                </div>
                <div className="flex items-center gap-2">
                  <div className="w-3 h-3 bg-gold rounded-full" />
                  <span>7日間平均</span>
                </div>
              </div>
            </Card>
          </div>

          <div className="space-y-6">
            <Card title="体重を記録する" icon={Plus}>
              <div className="space-y-4">
                <div className="relative">
                  <input 
                    type="number" 
                    step="0.1"
                    placeholder="0.0"
                    value={newWeight}
                    onChange={(e) => setNewWeight(e.target.value)}
                    className="w-full bg-stone-50 border-none rounded-xl px-4 py-3 text-2xl font-serif font-bold focus:ring-2 focus:ring-sage/20 transition-all"
                  />
                  <span className="absolute right-4 top-1/2 -translate-y-1/2 text-stone-400 font-bold">kg</span>
                </div>
                <Button onClick={addWeightLog} className="w-full" variant="primary">
                  今日の体重を保存
                </Button>
              </div>
            </Card>

            <Card title="目標を設定する" icon={Target}>
              <div className="space-y-4">
                <div>
                  <label className="text-[10px] font-bold uppercase tracking-wider text-stone-400 mb-1 block">目標体重</label>
                  <input 
                    type="number" 
                    placeholder="目標 (kg)"
                    value={goalInput.targetWeight}
                    onChange={(e) => setGoalInput({ ...goalInput, targetWeight: e.target.value })}
                    className="w-full bg-stone-50 border-none rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-sage/20 transition-all"
                  />
                </div>
                <div>
                  <label className="text-[10px] font-bold uppercase tracking-wider text-stone-400 mb-1 block">目標期日</label>
                  <input 
                    type="date" 
                    value={goalInput.targetDate}
                    onChange={(e) => setGoalInput({ ...goalInput, targetDate: e.target.value })}
                    className="w-full bg-stone-50 border-none rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-sage/20 transition-all"
                  />
                </div>
                <Button onClick={updateGoals} className="w-full" variant="outline">
                  目標を更新
                </Button>
              </div>
            </Card>
          </div>
        </section>

        {/* --- 宅トレセクション --- */}
        <section id="exercises" className="space-y-6">
          <div className="flex items-center justify-between">
            <h2 className="text-2xl font-serif font-bold text-stone-800">宅トレガイド</h2>
            <div className="text-xs font-medium text-stone-400 bg-stone-100 px-3 py-1 rounded-full">
              {exercises.filter(e => e.completed).length} / {exercises.length} 完了
            </div>
          </div>
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            {exercises.map((ex) => (
              <motion.div 
                key={ex.id}
                whileHover={{ y: -4 }}
                onClick={() => toggleExercise(ex.id)}
                className={cn(
                  "p-5 rounded-2xl border transition-all cursor-pointer group relative overflow-hidden",
                  ex.completed 
                    ? "bg-sage/10 border-sage/30" 
                    : "bg-white border-stone-100 hover:border-sage/50"
                )}
              >
                <div className="flex items-start justify-between mb-3">
                  <div className={cn(
                    "w-10 h-10 rounded-xl flex items-center justify-center transition-colors",
                    ex.completed ? "bg-sage text-white" : "bg-stone-50 text-stone-400 group-hover:text-sage"
                  )}>
                    {ex.completed ? <CheckCircle2 className="w-6 h-6" /> : <Dumbbell className="w-5 h-5" />}
                  </div>
                </div>
                <h4 className={cn("font-bold text-sm mb-1", ex.completed ? "text-sage" : "text-stone-800")}>{ex.label}</h4>
                <p className="text-[10px] text-stone-400 leading-relaxed">{ex.tip}</p>
                
                {ex.completed && (
                  <motion.div 
                    initial={{ scale: 0 }}
                    animate={{ scale: 1 }}
                    className="absolute -right-2 -bottom-2 opacity-10"
                  >
                    <CheckCircle2 className="w-16 h-16 text-sage" />
                  </motion.div>
                )}
              </motion.div>
            ))}
          </div>
        </section>

        {/* --- レシピセクション --- */}
        <section id="recipes">
          <Card title="冷蔵庫レシピ" icon={ChefHat} className="bg-stone-50/50 border-dashed border-2">
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-10">
              <div className="space-y-6">
                <div>
                  <h3 className="text-xl font-serif font-bold text-stone-800 mb-2">食材から選ぶ</h3>
                  <p className="text-sm text-stone-500 mb-4">冷蔵庫にある食材を教えてください。AIシェフがヘルシーな一皿をご提案します。</p>
                  <textarea 
                    placeholder="例：ほうれん草、鶏むね肉、レモン、にんにく..."
                    value={ingredients}
                    onChange={(e) => setIngredients(e.target.value)}
                    className="w-full h-32 bg-white border border-stone-200 rounded-2xl p-4 text-sm focus:ring-2 focus:ring-sage/20 transition-all resize-none"
                  />
                </div>
                <Button 
                  onClick={generateRecipe} 
                  variant="terracotta" 
                  className="w-full py-4 shadow-lg shadow-terracotta/20"
                  loading={isGenerating}
                >
                  <UtensilsCrossed className="w-5 h-5" />
                  ヘルシーレシピを生成
                </Button>
              </div>

              <div className="bg-white rounded-2xl p-6 min-h-[300px] border border-stone-100 shadow-inner relative">
                <AnimatePresence mode="wait">
                  {recipe ? (
                    <motion.div 
                      key="recipe"
                      initial={{ opacity: 0 }}
                      animate={{ opacity: 1 }}
                      exit={{ opacity: 0 }}
                      className="prose prose-sm prose-stone max-w-none"
                    >
                      <div className="whitespace-pre-wrap font-sans text-stone-700 leading-relaxed">
                        {recipe}
                      </div>
                    </motion.div>
                  ) : (
                    <motion.div 
                      key="placeholder"
                      initial={{ opacity: 0 }}
                      animate={{ opacity: 1 }}
                      className="h-full flex flex-col items-center justify-center text-center text-stone-300"
                    >
                      <ChefHat className="w-12 h-12 mb-4 opacity-20" />
                      <p className="text-sm font-medium">こちらにレシピが表示されます...</p>
                    </motion.div>
                  )}
                </AnimatePresence>
                
                {isGenerating && (
                  <div className="absolute inset-0 bg-white/80 backdrop-blur-sm flex flex-col items-center justify-center rounded-2xl">
                    <Loader2 className="w-8 h-8 text-terracotta animate-spin mb-2" />
                    <p className="text-xs font-bold text-terracotta uppercase tracking-widest">レシピを作成中...</p>
                  </div>
                )}
              </div>
            </div>
          </Card>
        </section>

      </main>

      {/* --- フッター --- */}
      <footer className="mt-20 py-10 border-t border-stone-100 text-center">
        <p className="text-xs font-bold text-stone-400 uppercase tracking-widest mb-2">Petit Santé</p>
        <p className="text-[10px] text-stone-300">© 2026 Petit Santé Atelier. All rights reserved.</p>
      </footer>

      {/* --- モバイルナビ --- */}
      <div className="md:hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-white/80 backdrop-blur-md border border-stone-100 rounded-full px-6 py-3 shadow-2xl flex items-center gap-8 z-50">
        <a href="#tracker" className="text-stone-400 hover:text-sage transition-colors"><Scale className="w-6 h-6" /></a>
        <a href="#exercises" className="text-stone-400 hover:text-sage transition-colors"><Dumbbell className="w-6 h-6" /></a>
        <a href="#recipes" className="text-stone-400 hover:text-sage transition-colors"><ChefHat className="w-6 h-6" /></a>
      </div>
    </div>
  );
}
